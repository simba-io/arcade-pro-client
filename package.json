{
  "name": "typescript-webpage-project",
  "version": "1.0.0",
  "description": "A TypeScript webpage project",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "serve": "npx http-server client -p 3000 -o",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "build:prod": "npm run clean && tsc --build"
  },
  "keywords": [
    "typescript",
    "webpage",
    "frontend"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/node": "^20.8.0",
    "http-server": "^14.1.1",
    "rimraf": "^5.0.5"
  },
  "dependencies": {},
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}